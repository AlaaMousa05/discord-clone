# Copy this file to .env.local (never commit .env.local) and fill in the
# values printed by `npx convex dev` on first run.

# The URL of your Convex deployment, used by the Convex React client.
VITE_CONVEX_URL=

# The HTTP Actions URL of your Convex deployment, used by Convex Auth.
VITE_CONVEX_SITE_URL=

# NOTE: JWT_PRIVATE_KEY, JWKS, and SITE_URL are NOT set here — they are
# server-side secrets that Convex Auth reads inside Convex functions, so
# they live on the Convex deployment itself (`npx convex env list`), not in
# this file. They were generated for this deployment by running:
#   npx @convex-dev/auth --skip-git-check --web-server-url http://localhost:5173
